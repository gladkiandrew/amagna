# apps/marketing environment template.
# Copy to .env.local and fill in real values. .env.local is gitignored — never commit secrets.

# --- Supabase ---
# API URL is https://<project-ref>.supabase.co (not the dashboard URL).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side ONLY — bypasses row-level security. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=
# Database password (Project Settings → Database). Needed only to run migrations.
SUPABASE_DB_PASSWORD=

# --- Anthropic (audit generator) ---
# Used by the /audit widget. Server-side only.
ANTHROPIC_API_KEY=

# --- Sapt (Phase 1.5 audit widget — primary data source for SERP / GBP signals) ---
SAPT_PROJECT_ID=
SAPT_API_KEY=

# --- Outbound email (Resend) ---
# Powers /custom-quote inquiries and the audit PDF follow-up.
RESEND_API_KEY=

# --- Booking (Cal.com) ---
# The /book page embeds this scheduling URL. Until set, /book shows an email fallback.
NEXT_PUBLIC_CALCOM_URL=

# --- Stripe (test mode first; flip to live once a client is ready to pay) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Stripe price IDs:
#   STRIPE_PRICE_GROWTH  — $1,497/mo recurring (Growth)
#   STRIPE_PRICE_UPDATE  — $500 one-time (Update website + GBP rebuild)
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_UPDATE=

# --- Meta pixel (Phase 1.5 ads tracking) ---
# Set this and PageView fires automatically; /audit submit fires Lead; /checkout/success fires Subscribe.
NEXT_PUBLIC_META_PIXEL_ID=
