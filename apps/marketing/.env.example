# apps/marketing environment template.
# Copy to .env.local and fill in real values. .env.local is gitignored — never commit secrets.

# --- Supabase ---
# API URL is https://<project-ref>.supabase.co (not the dashboard URL).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side ONLY — bypasses row-level security. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=
# Database password (Project Settings → Database). Needed only to run migrations.
SUPABASE_DB_PASSWORD=

# --- Outbound email (Resend) ---
# Powers the /custom-quote inquiry email. Until set, submissions are logged server-side.
RESEND_API_KEY=

# --- Booking (Calendly) ---
# The /book page embeds this scheduling URL. Until set, /book shows an email fallback.
NEXT_PUBLIC_CALENDLY_URL=
