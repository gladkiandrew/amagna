# Amagna AI — Environment Variables Template
#
# Copy this file to `.env.local` (which is gitignored) and fill in real values.
# NEVER commit `.env.local`. NEVER share these keys.
#
# Run `cp .env.example .env.local` to get started.

# -----------------------------------------------------------------------------
# Anthropic (Claude API)
# -----------------------------------------------------------------------------
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
# Get from: https://supabase.com/dashboard → your project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJh...
SUPABASE_SERVICE_ROLE_KEY=eyJh...

# Public-facing (for use in browser code)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJh...

# -----------------------------------------------------------------------------
# Cloudflare
# -----------------------------------------------------------------------------
# Get from: https://dash.cloudflare.com → My Profile → API Tokens
CLOUDFLARE_API_TOKEN=...
CLOUDFLARE_ACCOUNT_ID=...

# -----------------------------------------------------------------------------
# Sapt (for agent integration)
# -----------------------------------------------------------------------------
# Get from: app.sapt.ai → Settings → API Keys
SAPT_API_KEY=...

# -----------------------------------------------------------------------------
# Optional: Analytics
# -----------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_GA_ID=
